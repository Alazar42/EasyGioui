// Number button components
@component Btn0 {
    Button {
        id: btn0
        text: "0"
        onClick: Calculator.Digit0
        style: {
            textColor: "blue"
        }
    }
}

@component Btn1 {
    Button {
        id: btn1
        text: "1"
        onClick: Calculator.Digit1
        style: {
            textColor: "blue"
        }
    }
}

@component Btn2 {
    Button {
        id: btn2
        text: "2"
        onClick: Calculator.Digit2
