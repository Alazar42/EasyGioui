// Operation button components
@component BtnAdd {
    Button {
        id: btnAdd
        text: "+"
        onClick: Calculator.OpAdd
        style: {
            textColor: "orange"
        }
    }
}

@component BtnSub {
    Button {
        id: btnSub
        text: "-"
        onClick: Calculator.OpSub
        style: {
            textColor: "orange"
        }
    }
}

@component BtnMul {
    Button {
        id: btnMul
        text: "*"
        onClick: Calculator.OpMul
        style: {
            textColor: "orange"
        }
    }
}

@component BtnDiv {
    Button {
        id: btnDiv
        text: "/"
        onClick: Calculator.OpDiv
        style: {
            textColor: "orange"
        }
    }
}

@component BtnEqual {
    Button {
        id: btnEqual
        text: "="
        onClick: Calculator.Equal
    }
}

@component BtnClear {
    Button {
        id: btnClear
        text: "C"
        onClick: Calculator.Clear
    }
}

@component BtnDecimal {
    Button {
        id: btnDec
        text: "."
        onClick: Calculator.Decimal
        style: {
            textColor: "gray"
        }
    }
}
